{
  "name": "agent-pages",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/index-sessions.mjs && vite --host 127.0.0.1 --port 47983 --strictPort",
    "build": "tsc -b && vite build",
    "build:demo": "VITE_AGENT_PAGES_DEMO=1 tsc -b && VITE_AGENT_PAGES_DEMO=1 vite build",
    "preview:demo": "bun run build:demo && vite preview --host 127.0.0.1 --port 47985 --strictPort",
    "build:pages": "VITE_AGENT_PAGES_DEMO=1 tsc -b && VITE_AGENT_PAGES_DEMO=1 vite build --base /agent-pages/",
    "preview": "vite preview --host 127.0.0.1 --port 47983 --strictPort",
    "index": "node scripts/index-sessions.mjs",
    "test": "bun test",
    "check": "node scripts/index-sessions.mjs && bun test && bun run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-grab": "0.1.37",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "three": "^0.184.0",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1"
  }
}
